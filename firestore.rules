rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /shared_trips/{tripId} {
      function signedIn() {
        return request.auth != null;
      }

      function isMember() {
        return signedIn() && request.auth.uid in resource.data.members;
      }

      function isManager() {
        return signedIn()
          && (
            resource.data.ownerId == request.auth.uid
            || request.auth.uid in resource.data.admins
          );
      }

      function isValidNewTrip() {
        return request.resource.data.keys().hasAll([
          'name',
          'expenses',
          'themes',
          'background',
          'joinCode',
          'ownerId',
          'admins',
          'members',
          'createdAt',
          'lastUpdated'
        ])
        && request.resource.data.keys().hasOnly([
          'name',
          'expenses',
          'themes',
          'background',
          'joinCode',
          'ownerId',
          'admins',
          'members',
          'createdAt',
          'lastUpdated'
        ])
        && tripId == request.resource.data.joinCode
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.admins == [request.auth.uid]
        && request.resource.data.members == [request.auth.uid]
        && request.resource.data.expenses is list
        && request.resource.data.themes is map
        && request.resource.data.background is string
        && request.resource.data.joinCode is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80;
      }

      function onlyAllowedMemberFieldsChanged() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'expenses',
          'themes',
          'background',
          'receiptImages',
          'lastUpdated'
        ]);
      }

      function validMemberUpdate() {
        return isMember()
          && onlyAllowedMemberFieldsChanged()
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.admins == resource.data.admins
          && request.resource.data.members == resource.data.members
          && request.resource.data.joinCode == resource.data.joinCode
          && request.resource.data.createdAt == resource.data.createdAt;
      }

      function validSelfJoin() {
        return signedIn()
          && !(request.auth.uid in resource.data.members)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
          && request.resource.data.members.hasAll(resource.data.members)
          && request.auth.uid in request.resource.data.members
          && request.resource.data.members.size() == resource.data.members.size() + 1;
      }

      function validLegacyOwnershipClaim() {
        return signedIn()
          && !resource.data.keys().hasAll(['ownerId', 'admins'])
          && resource.data.members.size() > 0
          && resource.data.members[0] == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownerId', 'admins'])
          && request.resource.data.ownerId == request.auth.uid
          && request.resource.data.admins == [request.auth.uid];
      }

      allow create: if signedIn() && isValidNewTrip();
      allow read: if isMember();
      allow update: if validMemberUpdate() || validSelfJoin() || validLegacyOwnershipClaim();
      allow delete: if isManager();
    }
  }
}
